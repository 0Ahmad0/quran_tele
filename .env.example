# Telegram bot token from @BotFather
# IMPORTANT: never put your real token in GitHub. Put the real token only in .env or hosting environment variables.
BOT_TOKEN=put_your_new_telegram_bot_token_here

# Your numeric Telegram user ID, for admin-only commands
# You can get it from @userinfobot
ADMIN_ID=123456789

# Timezone used by the scheduler
# Examples: Africa/Cairo, Asia/Riyadh, UTC
TIMEZONE=Africa/Cairo
